# Finely Cred — copy to `.env.local` for local dev (never commit secrets)

# Optional: canonical site URL for sitemap generation (defaults to https://finelycred.com)
# VITE_SITE_URL=https://finelycred.com

# Supabase (required for live auth, partners, letters sync)
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key

# Private storage bucket for PII (reports, letter PDFs, evidence)
# Must match bucket id created in supabase/LIVE_SETUP_run_all.sql (default: pii)
VITE_SUPABASE_PRIVATE_BUCKET=pii

# Optional: Stripe (portal checkout)
# VITE_STRIPE_PUBLISHABLE_KEY=pk_live_...

# Optional: SmartCredit affiliate PID (defaults to 54821 placeholder)
# VITE_SMARTCREDIT_PID=54821

# Optional: Playwright portal QA when Supabase keys are set (real auth)
# E2E_TEST_EMAIL=partner@test.com
# E2E_TEST_PASSWORD=your_test_password

# --- Supabase Edge Function secrets (set in Supabase dashboard, NOT in Vite) ---
# SUPABASE_SERVICE_ROLE_KEY=...
# EDGE_ADMIN_EMAILS=admin@example.com,ops@example.com
# META_APP_SECRET=...
# NORA_CAPITAL_BASE_URL=...
# NORA_CAPITAL_API_KEY=...
# NORA_CAPITAL_WEBHOOK_SECRET=...
# NORA_CAPITAL_ALLOWED_PATHS_JSON=["/ping","/v1/applications"]
# FINELY_PARTNER_API_KEYS_JSON=["your_nora_read_key"]
# STRIPE_SECRET_KEY=...
# STRIPE_WEBHOOK_SECRET=...
# APP_BASE_URL=https://app.finelycred.com  (Stripe success/cancel URLs + public session checkout)
# SENDGRID_API_KEY=...  (invite + nurture delivery)
# TWILIO_*=...          (invite SMS)
# ELEVENLABS_API_KEY=... (custom clone + fallback)
# ELEVENLABS_MODEL=eleven_multilingual_v2
# VOICE_CLONE_FINELY_PRIMARY_ID=... (your brand clone)
# VOICE_CLONE_NORA_PRIMARY_ID=... (optional Nora clone)
# ELEVENLABS_VOICE_FINELY_FEMALE_WARM=...
# ELEVENLABS_VOICE_FINELY_MALE_CALM=...
# ELEVENLABS_VOICE_FINELY_DOCUMENTARY=...
# CARTESIA_API_KEY=... (premium preset quality — recommended)
# CARTESIA_MODEL=sonic-2
# FINELY_BRIDGE_WEBHOOK_SECRET=... (optional HMAC for finely-bridge-webhook)
# VITE_PROVIDER_GATEWAY_URL=https://your-bridge-gateway.example.com
# VITE_FINELY_CRED_API_URL=https://YOUR_PROJECT.supabase.co/functions/v1/finely-partner-api
# OPENAI_API_KEY=...     (AI gateway + ML advisory v4 fallback)
# OPENAI_TTS_MODEL=tts-1-hd
# VOICE_PIPELINE_VERSION=v1

# Optional: allow browser TTS preview in production builds (default: dev-only)
# VITE_VOICE_ALLOW_BROWSER_PREVIEW=false
